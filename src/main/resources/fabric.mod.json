{
	"schemaVersion": 1,
	"id": "zuron",
	"version": "${version}",
	"name": "zuron",
	"description": "a project that aims to allow users to use javascript, python and lua in modern versions of minecraft",
	"authors": [
		"DocilElm"
	],
	"contact": {
		"homepage": "https://github.com/Synnerz/",
		"sources": "https://github.com/Synnerz/"
	},
	"license": "GPL-3.0",
	"icon": "assets/zuron/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "com.github.synnerz.zuron.Zuron",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"zuron.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.10",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": ">=1.13.9+kotlin.2.3.10"
	}
}